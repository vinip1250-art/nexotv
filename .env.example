# ==============================================================================
#                         ESSENTIAL ADDON SETUP
# ==============================================================================
# Customize your addon identity. These are shown in Stremio and the config page.

# --- Addon Identity ---
# Descriptive name for your addon instance.
ADDON_NAME=NexoTV
# Short description shown in Stremio.
ADDON_DESCRIPTION=Stream your IPTV channels in Stremio
# Logo/icon image to display in Stremio and on the configure page.
# To use a local image, place it in packages/frontend/public/assets/ and point here:
#   ADDON_LOGO_URL=http://localhost:7000/assets/logo.svg
# Or use any external URL:
#   ADDON_LOGO_URL=https://example.com/logo.png
# Default: packages/frontend/public/assets/logo.svg (served from GitHub raw)
# ADDON_LOGO_URL=

# --- Network ---
# Port to run the HTTP server on.
# Default: 7000
# PORT=7000


# ==============================================================================
#                              SECURITY
# ==============================================================================

# Optional secret to enable AES-256-GCM encryption for configuration tokens.
# Strongly recommended for public deployments. Must be >= 16 characters.
# Generate a random value with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# CONFIG_SECRET=change_this_to_a_long_random_secret_string


# ==============================================================================
#                           CACHE CONFIGURATION
# ==============================================================================
# All cache variables have sensible defaults. Uncomment only what you want to change.

# --- SQLite Persistent Cache ---
# Enable/disable persistent SQLite caching.
# Default: true
# CACHE_ENABLED=true

# Path to the SQLite cache file. In Docker, set to /app/data/cache.sqlite and mount a volume.
# Default: ./data/cache.sqlite
# SQLITE_PATH=./data/cache.sqlite

# --- Optional Redis Persistent Cache ---
# If REDIS_URL is set, Redis is used for persistent addon data instead of SQLite.
# Leave unset for local development. Example for a VPS compose service named "redis":
# REDIS_URL=redis://redis:6379
# REDIS_KEY_PREFIX=nexotv:

# How often (ms) to delete expired entries from the database.
# Default: 21600000 (6 hours)
# SQLITE_GC_INTERVAL_MS=21600000

# How often (ms) to run VACUUM and reclaim free disk space.
# VACUUM rewrites the whole DB file — run it infrequently.
# Default: 604800000 (7 days)
# SQLITE_VACUUM_INTERVAL_MS=604800000

# --- Cache TTLs ---
# How long (ms) Xtream Codes data is cached.
# Default: 21600000 (6 hours)
# CACHE_TTL_MS=21600000

# How long (ms) IPTV-org data is cached.
# Default: 21600000 (6 hours)
# IPTV_ORG_CACHE_TTL_MS=21600000

# How long (ms) M3U/M3U+ playlist data is cached.
# Default: 21600000 (6 hours)
# M3U_CACHE_TTL_MS=21600000

# --- In-Memory Eviction ---
# How long (ms) channel/EPG data stays in RAM after the last request before being evicted.
# Data is reloaded from SQLite on demand. Lower = less RAM, more SQLite reads.
# Default: 300000 (5 minutes)
# DATA_MEMORY_TTL_MS=300000

# Max in-memory addon instances (lightweight — channel data lives in SQLite, not RAM).
# Default: 300
# MAX_CACHE_ENTRIES=300

# --- Logo Cache ---
# Enable/disable Cache-Control headers on proxied logos.
# Default: true
# LOGO_CACHE_ENABLED=true


# ==============================================================================
#                             PREFETCH PROXY
# ==============================================================================
# Server-side prefetch proxy that bypasses browser CORS for playlist/EPG validation.

# Enable/disable the prefetch proxy.
# Default: true
# PREFETCH_ENABLED=true

# Max bytes the prefetch proxy will download per request.
# Default: 150000000 (~150 MB)
# PREFETCH_MAX_BYTES=150000000


# ==============================================================================
#                           RATE LIMITING
# ==============================================================================
# Protects the server from abuse. Defaults are suitable for most deployments.

# --- Global IP Rate Limit ---
# Default: true
# IP_RATE_LIMIT_ENABLED=true
# Window in ms.  Default: 300000 (5 minutes)
# IP_RATE_LIMIT_WINDOW_MS=300000
# Max requests per window.  Default: 300
# IP_RATE_LIMIT_MAX=300

# --- Per-Token Rate Limit (addon routes) ---
# Default: true
# TOKEN_RATE_LIMIT_ENABLED=true
# Window in ms.  Default: 60000 (1 minute)
# TOKEN_RATE_LIMIT_WINDOW_MS=60000
# Max requests per window.  Default: 60
# TOKEN_RATE_LIMIT_MAX=60


# ==============================================================================
#                         DATA REFRESH INTERVALS
# ==============================================================================
# Controls how often the addon re-fetches channel and EPG data from providers.

# How often (ms) the addon checks for updated channel/EPG data from the provider.
# Default: 3600000 (1 hour)
# UPDATE_INTERVAL_MS=3600000

# Minimum time (ms) between re-fetches when channels are already loaded.
# Acts as a floor to avoid hammering the provider. Must be <= UPDATE_INTERVAL_MS.
# Default: 900000 (15 minutes)
# MIN_UPDATE_INTERVAL_MS=900000

# How often (ms) EPG/XMLTV data is re-fetched and re-parsed. EPG changes less
# frequently than channel lists, so this defaults to 2× UPDATE_INTERVAL_MS.
# Default: 28800000 (8 hours)
# EPG_UPDATE_INTERVAL_MS=28800000


# ==============================================================================
#                           FETCH TIMEOUTS
# ==============================================================================
# Network timeouts for outbound requests. Increase if your provider is slow.

# Timeout (ms) for fetching channel streams and M3U playlists.
# Default: 30000 (30 seconds)
# FETCH_TIMEOUT_MS=30000

# Timeout (ms) for fetching EPG/XMLTV files (these are typically large).
# Default: 60000 (60 seconds)
# EPG_FETCH_TIMEOUT_MS=60000

# Timeout (ms) for the prefetch proxy endpoint.
# Default: 45000 (45 seconds)
# PREFETCH_TIMEOUT_MS=45000

# Timeout (ms) for logo proxy HEAD and GET requests.
# Default: 10000 (10 seconds)
# LOGO_TIMEOUT_MS=10000


# ==============================================================================
#                           CATALOG & EPG LIMITS
# ==============================================================================

# Number of channels returned per catalog page in Stremio.
# Default: 100
# CATALOG_PAGE_SIZE=100

# Maximum EPG/XMLTV file size the server will parse (bytes).
# Files larger than this are skipped to protect memory.
# Default: 104857600 (100 MB)
# EPG_MAX_BYTES=104857600


# ==============================================================================
#                           ADVANCED / DEBUGGING
# ==============================================================================

# Allow localhost/private IPs as stream/playlist sources (useful for local testing).
# Default: false
# ALLOW_LOCAL_URLS=false

# Enable verbose debug logging.
# Default: false
# DEBUG_MODE=false


# ==============================================================================
#                              MONITORING
# ==============================================================================
# Watchdog that samples memory/CPU every interval and logs warnings at thresholds.
# At CRITICAL threshold, the oldest half of idle LRU addon instances are evicted
# to relieve RAM pressure. Defaults are high so this is a no-op on normal servers.

# How often (ms) to sample heap and CPU.
# Default: 30000 (30 seconds)
# METRICS_SAMPLE_INTERVAL_MS=30000

# Heap size (MB) that triggers a [WARN] log.
# Default: 512
# METRICS_WARN_HEAP_MB=512

# Heap size (MB) that triggers [ERROR] + auto-eviction of idle LRU instances.
# Set below NODE_OPTIONS --max-old-space-size to catch pressure before OOM.
# Default: 768
# METRICS_CRITICAL_HEAP_MB=768
