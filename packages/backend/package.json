{
  "name": "@nexotv/backend",
  "version": "2.1.0",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "tsx watch server.ts",
    "build": "tsc",
    "build:check": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "test:bench": "vitest bench --run --config vitest.bench.config.ts"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "compression": "^1.8.1",
    "dotenv": "^17.2.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "redis": "^4.7.0",
    "stremio-addon-sdk": "^1.6.10",
    "xml2js": "^0.4.23"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/compression": "^1.7.5",
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "@types/supertest": "^6.0.2",
    "@types/xml2js": "^0.4.14",
    "@vitest/coverage-v8": "^2.1.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
